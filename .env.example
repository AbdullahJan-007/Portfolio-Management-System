# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git — it is already ignored by .gitignore.

# PostgreSQL connection string.
#
# Local development options:
#   - Docker:   docker run --name portfolio-db -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
#               DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio"
#   - Or use any free managed Postgres for local + production, e.g. Neon (neon.tech)
#     or Supabase (supabase.com) — both have a generous free tier and give you
#     a connection string in under a minute.
#
# Production (Vercel): add this same variable in
#   Vercel Dashboard → Project → Settings → Environment Variables
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign session JWTs. MUST be a long, random string (32+ chars).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
